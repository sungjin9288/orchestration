# Orchestration 1.0 — optional environment variables.
#
# The default path is local-stub based and needs NO environment variables.
# The variables below only apply when a project explicitly opts into the
# OpenAI Responses live-provider adapter. When they are absent, live-provider
# checks are skipped (not failed). Copy this file to `.env` and fill in values
# only if you are exercising the optional live path.

# Secret API key read from the process environment by the OpenAI Responses
# adapter when a project opts in. Never commit a real key.
OPENAI_API_KEY=

# Optional model id used by live-provider smoke/verification scripts.
OPENAI_RESPONSES_MODEL=

# Optional adapter timeout override, in milliseconds.
OPENAI_RESPONSES_TIMEOUT_MS=

# Optional retry attempt override for 429/5xx responses.
OPENAI_RESPONSES_MAX_RETRY_ATTEMPTS=

# Optional retry delay override, in milliseconds.
OPENAI_RESPONSES_RETRY_DELAY_MS=

# Operational: how long scripts/verification_status.mjs waits for the aggregate
# lock before failing, in milliseconds (used by the verification gate).
ORCHESTRATION_VERIFICATION_LOCK_WAIT_MS=

# Optional exact-URL research adapter. Both values are required to open the
# route; the executable must be installed outside this repository.
ORCHESTRATION_WIGOLO_EXACT_FETCH_ENABLED=
ORCHESTRATION_WIGOLO_SIDECAR_PATH=

# Optional live-smoke target. Synthetic aggregate verification does not need it.
ORCHESTRATION_WIGOLO_LIVE_URL=
