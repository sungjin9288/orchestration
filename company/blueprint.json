{
  "schemaVersion": 1,
  "companyId": "orchestration-local-company",
  "displayName": "Orchestration AI Company",
  "operatingPrinciples": [
    "Repo files define policy and runtime state records execution evidence.",
    "Every execution requires project_path and explicit authority.",
    "Review precedes done and approval precedes mutation or commit.",
    "Agent output is evidence, not authority."
  ],
  "defaultStaffingPolicy": {
    "defaultMode": "council",
    "requiredCouncilAgentIds": [
      "agent-conductor",
      "agent-strategist",
      "agent-architect",
      "agent-decomposer"
    ],
    "parallelSpecialistsAllowed": false
  },
  "defaultTerminationPolicy": {
    "maxTurnsPerAgent": 4,
    "maxProviderCalls": 5,
    "deadlineMs": 300000,
    "stopOnRequiredRoleFailure": true
  },
