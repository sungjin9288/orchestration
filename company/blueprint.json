        "read": ["project.read", "source.read", "artifact.read", "evidence.read", "runtime.read"],
        "write": [],
        "deny": ["source.write", "memory.write", "provider.call", "commit", "push", "release"]
      },
      "workspacePolicy": {
        "mode": "shared-readonly",
        "projectPathRequired": true
      },
      "sessionPolicy": {
        "scope": "mission-role",
        "resumeAllowed": false
      },
      "providerPolicy": {
        "allowedModes": ["local-stub", "openai-responses"]
